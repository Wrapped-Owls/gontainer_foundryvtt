# syntax=docker/dockerfile:1

FROM nixos/nix:latest AS builder

WORKDIR /src
COPY . .

RUN nix build .#taverncord \
      --extra-experimental-features "nix-command flakes" \
      --option sandbox false \
      --option filter-syscalls false \
      --print-out-paths --no-link > /tmp/taverncord-path

RUN mkdir -p /out \
 && cp "$(cat /tmp/taverncord-path)/bin/taverncord" /out/taverncord

FROM alpine:3.21 AS runtime

LABEL org.opencontainers.image.source="https://github.com/wrapped-owls/gontainer_foundryvtt"
LABEL org.opencontainers.image.description="TavernCord Discord bot for FoundryVTT"

RUN apk add --no-cache ca-certificates tzdata

COPY --from=builder /out/taverncord /usr/local/bin/taverncord

ENTRYPOINT ["taverncord"]
